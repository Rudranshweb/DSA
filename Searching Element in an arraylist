import java.util.ArrayList;

public class Main {
    public static void main(String[] args) {

        ArrayList<Integer> list = new ArrayList<>();

        list.add(10);
        list.add(20);
        list.add(30);
        list.add(40);

        int key = 30;

        if(list.contains(key)){
            System.out.println(key + " is Found in the ArrayList");
        } else {
            System.out.println(key + " is Not Found in the ArrayList");
        }
    }
}
